# Talkify (obrigatório)
TALKIFY_API_KEY=tk_SUA_KEY_AQUI
TALKIFY_URL=https://api.talkifylabs.com
TALKIFY_VOICE_ID_PT=
TALKIFY_VOICE_ID_ES=
TALKIFY_TEMPO=1.05
TALKIFY_POLL_INTERVAL=4000
TALKIFY_TIMEOUT=180000

# Webhook server
WEBHOOK_PORT=5581
BATCH_MAX=13
BATCH_WAIT_MS=1800000
BATCH_MIN_ON_TIMEOUT=2

# Supabase (opcional — só se quiser sync com Syntax Kanban)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Concorrência
MAX_CONCURRENT_TTS=2
MAX_CONCURRENT_FFMPEG=1

# PNG overlay (avatar do espírito) — opcional como default; melhor mandar via webhook payload
DEFAULT_PNG_DIR=
DEFAULT_PNG_PATH=
PNG_HEIGHT_PCT=0.70

# Pêndulo (movimento do PNG)
PENDULUM_AMPLITUDE=0.04
PENDULUM_FREQUENCY=0.15

# Backgrounds (slideshow) — opcional como default; melhor mandar via webhook payload
DEFAULT_BACKGROUNDS_DIR=
BG_SEGMENT_DURATION=8
